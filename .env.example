# API keys. Prefer storing these in the OS keyring via `/key set <key>` inside the
# app (auto-detected by prefix). These env vars are the fallback if no keyring
# entry exists. Set only the provider(s) you use; switch with `/provider set`.
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...
